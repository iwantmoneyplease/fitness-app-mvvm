<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="fitness_app_mvvm.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:fitness_app_mvvm.View"
     Title="fitness_app_mvvm">

    <TabBar Shell.ForegroundColor="#0F0"
            Shell.TabBarBackgroundColor="DarkRed"
            Shell.TabBarTitleColor="White"
            Shell.TabBarUnselectedColor="red">
        <!-- Style koden påverkar endast Tabben högst upp i view inte där man faktiskt ändrar sin page -->
        <Tab Title="Home">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}"/>
        </Tab>
        <Tab Title="Add">
            <ShellContent ContentTemplate="{DataTemplate local:CreatePage}"/>
        </Tab>
        <Tab Title="Settings">
            <ShellContent ContentTemplate="{DataTemplate local:SettingsPage}"/>
        </Tab>
    </TabBar>


</Shell>