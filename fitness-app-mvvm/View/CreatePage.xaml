<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="fitness_app_mvvm.View.CreatePage"
             Title="CreatePage">
    <!-- Full ChatGPT kod -->
    <!-- Länk till konversation: https://chatgpt.com/share/69b19551-bf10-8013-9e70-1f69e97d7a37 -->
    <VerticalStackLayout Padding="20">

        <!-- Type buttons -->
        <CollectionView ItemsSource="{Binding Types}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Button
                    Text="{Binding Name}"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectTypeCommand}"
                    CommandParameter="{Binding .}" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Property buttons -->
        <CollectionView ItemsSource="{Binding Properties}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Button
                    Text="{Binding .}"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectPropertyCommand}"
                    CommandParameter="{Binding .}" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>