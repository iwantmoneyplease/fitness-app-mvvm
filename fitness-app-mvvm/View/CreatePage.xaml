<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="fitness_app_mvvm.View.MainPage">
    
    <VerticalStackLayout>
        <Label Text="Vilken typ av workout?" />

        <Button Text="Arm" Command="{Binding ArmCommand}" />
        <Button Text="Leg" Command="{Binding LegCommand}" />
        <Button Text="Core" Command="{Binding CoreCommand}" />

        <CollectionView 
            ItemsSource="{Binding SortOptions}"
            IsVisible="{Binding ShowSortOptions}">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Button Text="{Binding .}" />
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>
    </VerticalStackLayout>
    
</ContentPage>



